PORT=3000

# 出站 HTTP：超时（毫秒）、可恢复错误时的最大重试次数（不含首次请求）、是否在 stderr 打印重试日志（1=开启）
# FETCH_TIMEOUT_MS=10000
# FETCH_MAX_RETRIES=2
# FETCH_LOG_RETRIES=1

# 出网代理（可选）
# dotenv 文件里不需要写 export，直接写 KEY=VALUE 即可。
# 你可以按自己的代理软件填写（示例使用 Clash 常见端口）：
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890

# 代理白名单域名（逗号分隔）
# 例如：api.binance.com,fapi.binance.com,api.coingecko.com
PROXY_ALLOWED_DOMAINS=api.binance.com,api1.binance.com,api2.binance.com,fapi.binance.com,api.coingecko.com,api.alternative.me,www.okx.com

# 新闻源（JSON 字符串）
# 例如：[{"url":"https://www.coindesk.com/arc/outboundfeeds/rss/","name":"CoinDesk"},{"url":"https://cointelegraph.com/rss","name":"Cointelegraph"}]
NEWS_RSS_SOURCES=[{"url":"https://www.coindesk.com/arc/outboundfeeds/rss/","name":"CoinDesk"},{"url":"https://cointelegraph.com/rss","name":"Cointelegraph"}]

# 直播源配置
# 数据源模式：generic(先抓页面取 token) / json(直接请求 JSON 接口) / mock(本地演示数据)
LIVE_PROVIDER=generic
# 用于从页面提取 token 的正则（第 1 个捕获组为 token）
LIVE_TOKEN_REGEX=token=([a-f0-9]{32})
# 直播列表在 JSON 中的路径（如 data.list）
LIVE_LIST_PATH=list
# 默认留空（不同站点反爬规则差异较大，需要你按目标站点填写）
# 示例：
# LIVE_PAGE_URL=https://example.com/live
# LIVE_API_URL=https://example.com/api/live/list?token={token}
# LIVE_REFERER=https://example.com/live
# LIVE_ORIGIN=https://example.com
LIVE_PAGE_URL=
LIVE_API_URL=
LIVE_REFERER=
LIVE_ORIGIN=
