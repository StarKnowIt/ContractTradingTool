{
  "name": "contract-trading-tool",
  "version": "1.0.0",
  "private": true,
  "description": "ContractTradingTool monorepo (Next.js web + Express API)",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "start:api": "npm --workspace apps/api start",
    "test:api": "npm --workspace apps/api test",
    "test:api:cov": "npm --workspace apps/api run test:cov",
    "test:web": "npm --workspace apps/web test",

    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "start:web": "npm --workspace apps/web run start",

    "lint": "npm --workspace apps/web run lint"
  }
}
